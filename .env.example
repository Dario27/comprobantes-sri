# --- Módulo SRI (Puppeteer) — Fase 1: login + listado ---

# Nivel de logs de pino (trace|debug|info|warn|error). Default: info
LOG_LEVEL=info

# Diagnóstico de Puppeteer:
# SRI_DEBUG=1   → Chromium visible (headful) + screenshots/HTML en logs/ + no cierra el browser tras error
# SRI_HEADFUL=1 → solo Chromium visible (sin el resto del modo debug)
# SRI_DEBUG_KEEP_OPEN=1 → mantiene el browser abierto tras usarse (post-mortem)
#SRI_DEBUG=0
#SRI_HEADFUL=0
#SRI_DEBUG_KEEP_OPEN=0

# Delay (ms) entre descargas para evitar rate limit del SRI. Default: 1000
# En producción se recomienda 2000-3000 para bajar la cadencia mecánica.
#SRI_DOWNLOAD_DELAY_MS=1000

# Jitter aleatorio (ms) añadido al delay entre descargas. 0 = desactivado.
# Con SRI_DOWNLOAD_DELAY_MS=3000 y SRI_DOWNLOAD_JITTER_MS=1500 el intervalo
# real es 3000-4500 ms, rompiendo el patrón fijo que penaliza reCAPTCHA. Default: 0
#SRI_DOWNLOAD_JITTER_MS=0

# Timeout (ms) de espera para que el portal entregue cada archivo descargado. Default: 20000
# 20 s es amplio para descargas legítimas lentas y 3× más rápido que antes (60 s) al detectar
# un bloqueo del portal.
#SRI_DOWNLOAD_TIMEOUT_MS=20000

# Número de fallos de descarga consecutivos que disparan el circuit breaker y abortan el
# job con mensaje claro (DOWNLOAD_BLOCKED). Se reinicia con cualquier descarga exitosa. Default: 3
#SRI_DOWNLOAD_FAIL_THRESHOLD=3

# Anti-reCAPTCHA Enterprise: el botón "Consultar" del SRI puntúa la sesión (score). Para
# subir el score conviene usar Chrome REAL + perfil persistente + modo visible:
#   SRI_HEADFUL=1                       → navegador visible (mejor score que headless)
#   SRI_EXECUTABLE_PATH=...chrome.exe   → ruta a Chrome instalado (no el Chromium de Puppeteer)
#   SRI_CHROME_CHANNEL=chrome           → alternativa a EXECUTABLE_PATH (usa el canal instalado)
#   SRI_USER_DATA_DIR=./.chrome-sri     → perfil persistente (cookies/historial dan confianza)
#                                         WARMUP: abre ese perfil a mano una primera vez,
#                                         navega al SRI y acepta cookies antes de la primera
#                                         corrida automática para "calentar" la sesión.
#SRI_EXECUTABLE_PATH=C:\Program Files\Google\Chrome\Application\chrome.exe
#SRI_CHROME_CHANNEL=chrome
#SRI_USER_DATA_DIR=C:\sri-bot\chrome-profile
# MEJOR OPCIÓN para el score: conectarse a un Chrome real YA abierto con depuración remota
# (perfil/historial/sesión de Google reales). Arráncalo así y deja esta var apuntando a él:
#   chrome.exe --remote-debugging-port=9222 --user-data-dir="C:\Users\SChilan\.chrome-sri"
#SRI_BROWSER_URL=http://127.0.0.1:9222

# --- Persistencia (Fase 2) ---
# Ruta del archivo SQLite. Default: ./data/sri.sqlite
#DB_PATH=./data/sri.sqlite
# Carpeta base para archivos descargados servidos por /api/files. Default: ./downloads
#DOWNLOAD_DIR=./downloads

# --- Autenticación del portal (Fase 4) ---
# Usuario superadmin inicial. Se crea automáticamente al arrancar si la tabla usuarios está vacía.
ADMIN_USER=admin
ADMIN_PASS=cambiar_en_produccion
# Clave de firma para cookies de sesión HttpOnly (mín. 32 chars).
# Generar con:  openssl rand -base64 32   o   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
SESSION_PASSWORD=

# --- Capa de empresas (Fase 3 A) ---
# Clave maestra (32 bytes en base64) para cifrar las claves SRI guardadas. OBLIGATORIA para
# crear/usar empresas. Genérala con:  npm run master:gen
MASTER_KEY=

# --- Integración API externa de empresas ---
# URL base del sistema multi-tenant al que se notifica cada empresa creada.
# Default: https://localhost:9999 (API .NET en desarrollo local).
#EXTERNAL_EMPRESAS_API_BASE_URL=https://localhost:9999

# Timeout (ms) para la llamada a la API externa. Default: 10000 (10 s).
#EXTERNAL_EMPRESAS_API_TIMEOUT_MS=10000

# Omitir verificación de certificado TLS (1 = sí, para localhost self-signed; 0 = verificar).
# IMPORTANTE: usa 0 en producción con un certificado válido.
#EXTERNAL_EMPRESAS_API_INSECURE_TLS=1

# Desactivar el sync externo sin modificar código (útil en pruebas). Default: 1 (habilitado).
#EXTERNAL_EMPRESAS_API_ENABLED=1

# --- Scheduler de descargas automáticas (Fase 3 C) ---
# Expresión cron del tick (formato node-cron). Default: '0 3 * * *' (3:00 AM diario).
# Ejemplos:
#   Diario a las 3 AM:    SCHEDULER_CRON=0 3 * * *
#   Cada 20 minutos:      SCHEDULER_CRON=*/20 * * * *

#SCHEDULER_CRON=0 3 * * *
# Pon SCHEDULER_ENABLED=0 para desactivar el arranque del scheduler (p. ej. en desarrollo).
#SCHEDULER_ENABLED=1